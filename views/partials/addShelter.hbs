<form class="ui stacked segment form" action="/dashboard/addshelter" method="POST">
  <div class="five fields">
    <div class="field">
      <label>Shelter name</label>
      <input type="text" name="cName" required title = "Please, tell us the shelter name"
	  placeholder="Shelter">
    </div>
    <div class="field">
      <label>Location</label>
      <input type="text" name="cLocation" required title = "Please include a valid location"
	  placeholder="Location"  >
    </div>
    <div class="field">
        <label>Phone number</label>
        <input type="text" name="cPhone" pattern="\+?\d+( \d+)*" required title = "Please include a valid phone number"
	  placeholder="e.g. +55 4355 3453">
    </div>
    <div class="field">
        <label>Rating (1-5)</label>
        <input type="number" min="1" max="5" name="cRating" required title = "Please include a valid rating"
	  placeholder="Rating">
    </div>
    <div class="field">
        <label>Image URL (optinal)</label>
        <input type="text" name="cImage" title = "Please include a valid image URL"
	  placeholder="Optional image">
    </div>
  </div>
  <button class="ui yellow submit button">Add Shelter</button>
</form>