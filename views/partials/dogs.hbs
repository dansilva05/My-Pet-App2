<input id="search" type="text" placeholder="Search" style="margin: 0px 0px 30px 30px;">

<div class="ui three stackable cards">
    {{#unless shelter.pet}}
    <div style="padding-left:30px;">
        <strong>
            No Dogs found for this shelter :/
        </strong>
    </div>
    {{else}}
    {{#each shelter.pet}}
    
    {{> listOneDog shelterId=../shelter.id}}
    {{> editDog shelterId=../shelter.id}}

    <script>
        document.querySelector("#showEdit{{@index}}").addEventListener('click', () => {
            document.querySelector("#dog{{@index}}").style.display = "none";
            document.querySelector("#edit{{@index}}").style.display = "block";
        })

        document.querySelector("#hideEdit{{@index}}").addEventListener('click', () => {
            document.querySelector("#dog{{@index}}").style.display = "block";
            document.querySelector("#edit{{@index}}").style.display = "none";
        })
    </script>
    {{/each}}

    {{/unless}}
</div>